@model List<MyShipping.Models.Payment>
@{
    ViewData["Title"] = "Payment History";
    var totalRevenue    = Model.Where(p => p.Status == MyShipping.Models.PaymentStatus.Completed).Sum(p => p.Amount);
    var totalRefunded   = Model.Where(p => p.Status == MyShipping.Models.PaymentStatus.Refunded).Sum(p => p.Amount);
}

<h2 class="fw-bold mb-4"><i class="bi bi-receipt me-2"></i>Payment History</h2>

<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="text-muted small">Total Paid</div>
            <div class="fs-4 fw-bold text-success">$@totalRevenue.ToString("N2")</div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="text-muted small">Refunded</div>
            <div class="fs-4 fw-bold text-secondary">$@totalRefunded.ToString("N2")</div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="text-muted small">Transactions</div>
            <div class="fs-4 fw-bold">@Model.Count</div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Shipment</th>
                        <th>Gateway</th>
                        <th>Transaction ID</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td class="text-muted small">@p.CreatedAt.ToString("MMM d, yyyy")</td>
                            <td>
                                @if (p.Shipment is not null)
                                {
                                    <a asp-controller="Shipments" asp-action="Details" asp-route-id="@p.ShipmentId"
                                       class="font-monospace text-decoration-none">@p.Shipment.TrackingNumber</a>
                                }
                            </td>
                            <td>
                                <i class="bi @(p.Gateway == MyShipping.Models.PaymentGateway.PayPal ? "bi-paypal" : p.Gateway == MyShipping.Models.PaymentGateway.BankTransfer ? "bi-bank" : "bi-credit-card") me-1"></i>
                                @p.Gateway
                            </td>
                            <td class="font-monospace small text-truncate" style="max-width:200px">
                                @(p.TransactionId ?? "—")
                            </td>
                            <td class="fw-semibold">$@p.Amount.ToString("N2")</td>
                            <td>
                                @{
                                    var badge = p.Status switch {
                                        MyShipping.Models.PaymentStatus.Completed => "bg-success",
                                        MyShipping.Models.PaymentStatus.Failed    => "bg-danger",
                                        MyShipping.Models.PaymentStatus.Refunded  => "bg-secondary",
                                        _                                          => "bg-warning text-dark",
                                    };
                                }
                                <span class="badge @badge">@p.Status</span>
                            </td>
                            <td>
                                @if (p.Status == MyShipping.Models.PaymentStatus.Completed)
                                {
                                    <form asp-action="Refund" method="post"
                                          onsubmit="return confirm('Refund this payment?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="paymentId" value="@p.Id" />
                                        <button class="btn btn-sm btn-outline-danger">Refund</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">No payment records found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
