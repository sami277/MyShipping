@model List<MyShipping.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
    var unread = Model.Count(n => !n.IsRead);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">
        <i class="bi bi-bell me-2"></i>Notifications
        @if (unread > 0)
        {
            <span class="badge bg-danger ms-2">@unread</span>
        }
    </h2>
    @if (unread > 0)
    {
        <form asp-action="MarkAllRead" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-check2-all me-1"></i>Mark all as read
            </button>
        </form>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-bell-slash display-4 mb-3 d-block"></i>
        You have no notifications.
    </div>
}
else
{
    <div class="list-group list-group-flush shadow-sm rounded">
        @foreach (var n in Model)
        {
            <div class="list-group-item list-group-item-action @(!n.IsRead ? "bg-primary bg-opacity-5" : "") d-flex gap-3 py-3">
                @{
                    var iconClass = n.Type switch {
                        MyShipping.Models.NotificationType.ShipmentCreated  => "bi-box-seam text-info",
                        MyShipping.Models.NotificationType.StatusUpdate     => "bi-arrow-repeat text-primary",
                        MyShipping.Models.NotificationType.PaymentConfirmed => "bi-check-circle-fill text-success",
                        MyShipping.Models.NotificationType.PaymentFailed    => "bi-x-circle-fill text-danger",
                        MyShipping.Models.NotificationType.DeliveryAlert    => "bi-truck text-warning",
                        _                                                   => "bi-bell text-secondary",
                    };
                }
                <div class="pt-1">
                    <i class="bi @iconClass fs-4"></i>
                </div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between">
                        <strong>@n.Title</strong>
                        <small class="text-muted">@n.CreatedAt.ToString("MMM d, HH:mm")</small>
                    </div>
                    <p class="mb-1 text-muted">@n.Message</p>
                    <div class="d-flex gap-2">
                        @if (n.ShipmentId.HasValue)
                        {
                            <a asp-controller="Shipments" asp-action="Details" asp-route-id="@n.ShipmentId"
                               class="btn btn-sm btn-outline-primary py-0">View Shipment</a>
                        }
                        @if (!n.IsRead)
                        {
                            <form asp-action="MarkRead" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@n.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary py-0">Mark read</button>
                            </form>
                        }
                        else
                        {
                            <span class="text-muted small"><i class="bi bi-check2"></i> Read</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
