@model List<MyShipping.Models.Shipment>
@{
    ViewData["Title"] = "My Shipments";
    var page     = (int)ViewBag.Page;
    var pageSize = (int)ViewBag.PageSize;
    var total    = (int)ViewBag.Total;
    var pages    = (int)Math.Ceiling(total / (double)pageSize);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="fw-bold"><i class="bi bi-box-seam me-2"></i>My Shipments</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>New Shipment</a>
</div>

<!-- Filters -->
<form method="get" class="row g-2 mb-3">
    <div class="col-sm-5">
        <input name="search" value="@ViewBag.Search" class="form-control" placeholder="Search tracking #, recipient…" />
    </div>
    <div class="col-sm-4">
        <select name="status" class="form-select">
            <option value="">All Statuses</option>
            @foreach (var s in Enum.GetValues<MyShipping.Models.ShipmentStatus>())
            {
                <option value="@s" selected="@(ViewBag.Status == s.ToString())">@s</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-funnel"></i> Filter</button>
        <a asp-action="Index" class="btn btn-link text-muted">Clear</a>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tracking #</th>
                        <th>Recipient</th>
                        <th>Destination</th>
                        <th>Service</th>
                        <th>Weight</th>
                        <th>Status</th>
                        <th>Payment</th>
                        <th>Cost</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td class="font-monospace fw-semibold">@s.TrackingNumber</td>
                            <td>@s.RecipientName</td>
                            <td class="text-truncate" style="max-width:140px" title="@s.RecipientAddress">@s.RecipientAddress</td>
                            <td><span class="badge bg-secondary">@s.ServiceType</span></td>
                            <td>@s.Weight kg</td>
                            <td>
                                @{
                                    var badge = s.Status switch {
                                        MyShipping.Models.ShipmentStatus.Delivered      => "bg-success",
                                        MyShipping.Models.ShipmentStatus.InTransit      => "bg-primary",
                                        MyShipping.Models.ShipmentStatus.OutForDelivery => "bg-info",
                                        MyShipping.Models.ShipmentStatus.Cancelled      => "bg-danger",
                                        MyShipping.Models.ShipmentStatus.Processing     => "bg-warning text-dark",
                                        _                                                => "bg-secondary",
                                    };
                                }
                                <span class="badge @badge">@s.Status</span>
                            </td>
                            <td>
                                @if (s.Payment?.Status == MyShipping.Models.PaymentStatus.Completed)
                                {
                                    <span class="badge bg-success">Paid</span>
                                }
                                else if (s.Payment?.Status == MyShipping.Models.PaymentStatus.Failed)
                                {
                                    <span class="badge bg-danger">Failed</span>
                                }
                                else
                                {
                                    <a asp-controller="Payments" asp-action="Pay" asp-route-shipmentId="@s.Id"
                                       class="badge bg-warning text-dark text-decoration-none">Pay Now</a>
                                }
                            </td>
                            <td>$@s.ShippingCost.ToString("N2")</td>
                            <td class="text-muted small">@s.CreatedAt.ToString("MMM d, yyyy")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@s.Id" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="10" class="text-center text-muted py-4">No shipments found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Pagination -->
@if (pages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= pages; i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-status="@ViewBag.Status"
                       asp-route-search="@ViewBag.Search">@i</a>
                </li>
            }
        </ul>
    </nav>
}
